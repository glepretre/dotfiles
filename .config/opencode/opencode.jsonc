{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/google/gemini-3-flash-preview",
  "small_model": "openrouter/google/gemini-3-flash-preview",
  "permission": {
    "read": {
      ".envrc": "ask"
    },
    "bash": {
      "gh *": "ask",
      "git push": "deny",
      "git push *": "deny",
      "rm *": "ask"
    }
  }
}
